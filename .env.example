# Database
DATABASE_URL=postgresql://user:password@localhost:5432/batch_picking

# NextAuth
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your-secret-here

# WooCommerce
WOO_API_URL=https://your-store.com
WOO_CONSUMER_KEY=ck_xxxxx
WOO_CONSUMER_SECRET=cs_xxxxx
WOO_WEBHOOK_SECRET=your_webhook_secret_here

# How many days back to sync 'processing' orders from (default: 7)
SYNC_DAYS_BACK=7

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-anon-key-here

# OpenRouter AI
OPENROUTER_API_KEY=sk-or-v1-...
OPENROUTER_MODEL=openai/gpt-4.1-mini
OPENROUTER_FALLBACK_MODEL=google/gemini-2.5-flash

